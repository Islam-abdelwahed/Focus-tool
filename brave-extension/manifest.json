{
  "manifest_version": 3,
  "name": "Focus Redirect",
  "description": "Redirects blocked domains from Focus to the localhost blocked page.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "declarativeNetRequest",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:4862/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Focus Redirect",
    "default_popup": "popup.html"
  }
}
